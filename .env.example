# Bodega — single source of truth for env vars (never commit real values)

# Base URL of the storefront (localhost in M0, Railway URL in M1+)
BODEGA_STORE_URL=http://localhost:3000

# Bearer token protecting /api/sessions + /api/verify (generate a random secret)
BODEGA_VERIFY_KEY=change-me

# Postgres connection string (docker-compose local / Railway prod)
DATABASE_URL=postgresql://bodega:bodega@localhost:5432/bodega

